{
  "name": "base-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev . --host 0.0.0.0",
    "docs:build": "vitepress build .",
    "docs:preview": "vitepress preview . --host 0.0.0.0",
    "docs:render": "bundlekit render --yaml-root product --md-root product --legacy-root product --no-index",
    "docs:render:common": "bundlekit render-common",
    "spec:normalize-gen": "bundlekit normalize",
    "spec:split": "bundlekit split",
    "spec:merge": "bundlekit merge",
    "spec:split:check": "bundlekit split --check",
    "spec:split:all": "bundlekit split-all",
    "spec:split:common": "bundlekit split-all --root product/common/yaml",
    "legacy-dynamics:validate": "bundlekit legacy-validate"
  },
  "devDependencies": {
    "@braintree/sanitize-url": "^7.1.2",
    "cytoscape": "^3.34.0",
    "cytoscape-cose-bilkent": "^4.1.0",
    "dayjs": "^1.11.21",
    "debug": "^4.4.3",
    "mermaid": "^11.16.0",
    "vitepress": "^1.6.4",
    "vitepress-mermaid-renderer": "^1.1.28",
    "vitepress-plugin-mermaid": "^2.0.17"
  }
}
