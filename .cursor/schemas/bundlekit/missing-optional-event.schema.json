{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://platform.local/schemas/bundlekit/missing-optional-event.schema.json",
  "title": "Bundlekit missing optional event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event",
    "package",
    "runId",
    "optional",
    "reason",
    "fallback",
    "metrics"
  ],
  "properties": {
    "event": {
      "const": "bundlekit.missing-optional"
    },
    "package": {
      "const": "@platform/bundlekit"
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "optional": {
      "enum": [
        "@platform/hubdocs",
        "@platform/artifactgraph",
        "codegraph"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "fallback": {
      "enum": [
        "deterministic",
        "local",
        "model"
      ]
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fileReads",
        "contextBytes"
      ],
      "properties": {
        "fileReads": {
          "type": "integer",
          "minimum": 0
        },
        "contextBytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
