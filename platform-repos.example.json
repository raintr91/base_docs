{
  "defaultGroup": "docs",
  "harness": {
    "defaultByRole": {
      "docs": "docs"
    },
    "syncPolicy": {
      "mode": "propose",
      "description": "Resolve the current repository only; do not sync skills from sibling repositories."
    },
    "profiles": {
      "docs": {
        "groups": [
          "docs"
        ],
        "skills": [
          "platform-ai",
          "docs-mark",
          "platform-mark",
          "architecture",
          "context",
          "containers",
          "component",
          "journey",
          "deployment",
          "cross-cutting",
          "decision",
          "hubdocs",
          "spec",
          "legacy-spec",
          "update-spec",
          "update-spec-legacy",
          "bqa-grill-docs",
          "dev-grill-docs",
          "grill-with-docs",
          "business-process-trace",
          "flow-trace",
          "business-impact-review",
          "dynamics"
        ],
        "note": "base-docs hub \u2014 repository-local docs harness only"
      }
    }
  },
  "groups": {
    "docs": {
      "description": "Docs hub \u2014 current repository only",
      "primary": "base-docs",
      "projects": [
        "base-docs"
      ]
    }
  },
  "projects": {
    "base-docs": {
      "root": ".",
      "role": "docs",
      "stack": "docs-c4",
      "repo": "base-docs",
      "url": "https://github.com/raintr91/base_docs",
      "skill": "platform-ai",
      "description": "Portable docs hub \u2014 C4 + product Code/common",
      "write": true,
      "specRoots": {
        "architecture": "architecture",
        "components": "product/components",
        "common": "product/common/code",
        "shared": "product/shared"
      },
      "docsSite": {
        "dev": "pnpm docs:dev",
        "root": "."
      }
    }
  },
  "$schema": "https://github.com/raintr91/platform-dna/blob/main/templates/schemas/platform-repos.schema.json"
}
