{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "hubdocs": {
      "type": "local",
      "command": [
        "wsl.exe",
        "-e",
        "bash",
        "-lc",
        "exec '/home/vutv/.nvm/versions/node/v24.14.1/bin/node' '/home/vutv/.hubdocs/bin/hubdocs-mcp.mjs'"
      ],
      "enabled": true,
      "environment": {
        "HUBDOCS_ROOT": "/home/vutv/workspace/base-docs"
      }
    }
  }
}
